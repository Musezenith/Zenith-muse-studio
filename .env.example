# Runtime/provider selection
# mock | vertex | openai | replicate | comfy
IMAGE_PROVIDER=mock
IMAGE_QUEUE=inline
IMAGE_QUEUE_WAIT_TIMEOUT_MS=45000
IMAGE_QUEUE_POLL_MS=200
IMAGEN_WORKER_POLL_MS=500

# Backward-compatible mock switch for current demo pipeline
MOCK_IMAGEN=1

# OpenAI provider settings (used when IMAGE_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_TIMEOUT_MS=30000

# API port guidance:
# - server uses PORT directly
# - API_PORT can be used by your shell/script to set PORT
API_PORT=8787
PORT=8787
